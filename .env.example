# NHS Jobs API Configuration
NHS_JOBS_KEYWORD=speech language therapist
NHS_JOBS_PAYBAND=BAND_5
NHS_JOBS_SORT=publicationDateDesc
NHS_JOBS_LIMIT=50

# Scheduler (cron expression)
CRON_EXPRESSION=*/15 * * * *

# Database
DATABASE_PATH=./data/jobs.db

# Email Configuration (Gmail)
# Note: For Gmail, you need an App Password, not your regular password
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_ENABLED=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# Recipients (comma separated for multiple)
EMAIL_TO=email1@gmail.com,email2@hotmail.com
